# LLM_PROVIDER=groq            # groq (default) | nebius | anthropic | bedrock
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# For LLM_PROVIDER=nebius (Nebius Token Factory, OpenAI-compatible API):
# NEBIUS_API_KEY=
# NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# PRECISO_REPO_ROOT=/absolute/path/to/preciso-graphrag
# PRECISO_AGENT_WORKSPACE=/absolute/path/to/preciso-agent/workspace
# OPENBB_HOME=/absolute/path/to/preciso-agent/.openbb_platform
# OPENBB is the source provider for SEC filings and related finance context in this agent.
# OPENBB_SOURCE_FORMAT=raw
# OPENBB_SEC_FORM_TYPES=10-K,10-Q,8-K
# PRECISO_QUERY_MODE=mix
